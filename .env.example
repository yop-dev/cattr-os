# ─── Database ────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me

# ─── App ─────────────────────────────────────────────────────────────────────
APP_KEY=base64:generate_with_artisan_key_generate
APP_URL=https://time.yourcompany.com   # used in invite email links

# ─── Initial admin account (only applied on first run) ───────────────────────
APP_ADMIN_EMAIL=admin@yourcompany.com
APP_ADMIN_PASSWORD=change_me
APP_ADMIN_NAME=Admin

# ─── Port binding ─────────────────────────────────────────────────────────────
# Local development:  APP_PORT=80
# Production (VPS):   APP_PORT=127.0.0.1:8080  ← Nginx proxies to this port
APP_PORT=80

# ─── SMTP (required for user invite emails) ──────────────────────────────────
# Recommended provider: Resend (resend.com) — free up to 3,000 emails/month
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=your-resend-api-key
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=cattr@yourcompany.com
MAIL_FROM_NAME=Cattr
